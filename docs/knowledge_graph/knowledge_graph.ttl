@prefix : <https://tangletech.dev/ips-automation-kg#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:Concept a rdfs:Class .
:Domain a rdfs:Class .
:Player a rdfs:Class .
:Root a rdfs:Class .
:Source a rdfs:Class .
:System a rdfs:Class .

:n_root a :Root ;
    rdfs:label "iPS自動培養ソフトウェア"@ja ;
    :content "患者血液→iPS樹立→維持/拡大→分化誘導→品質評価までを、画像判断・ロボット操作・規制対応を統合して自動制御するソフトウェアスタック。本マップはその実装に必要なドメイン知識の地図。"@ja ;
    :hasSource [ dct:title "iPS財団 My iPSプロジェクト（自家細胞を自動作製）"@ja ; :url <https://www.nikkan.co.jp/articles/view/00745986> ] ,
               [ dct:title "my iPSプロジェクト（iPS財団 公式）"@ja ; :url <https://www.cira-foundation.or.jp/j/about/project/myips/> ] .
:n_d1 a :Domain ;
    rdfs:label "細胞生物学・培養プロトコル"@ja ;
    :content "自動化の対象そのもの。iPS細胞の樹立・維持・継代・分化誘導・量産の生物学的手順群で、各操作のパラメータが下流の制御変数になる。"@ja ;
    :inDomain :n_d1 ;
    :hasSource [ dct:title "CiRA ヒトiPS細胞 培養プロトコール集"@ja ; :url <https://www.cira.kyoto-u.ac.jp/j/research/protocol.html> ] .
:n_d2 a :Domain ;
    rdfs:label "画像取得・コンピュータビジョン"@ja ;
    :content "ラベルフリー画像から細胞状態を定量し、意思決定の入力を生成する層。コンフルエンシー・形態・分化の判定が中核。"@ja ;
    :inDomain :n_d2 ;
    :hasSource [ dct:title "Deep learning for label-free monitoring of iPSC & organoids"@ja ; :url <https://www.moleculardevices.com/en/assets/app-note/dd/img/deep-learning-based-image-analysis-for-label-free-live-monitoring-of-ipsc-and-3d-organoid-cultures> ] .
:n_d3 a :Domain ;
    rdfs:label "ロボティクス・液体ハンドリング"@ja ;
    :content "培養操作を物理的に実行する装置・ロボット層。汎用双腕と閉鎖型専用機の二系統がある。"@ja ;
    :inDomain :n_d3 ;
    :hasSource [ dct:title "Robotic search for optimal cell culture（Kanda et al., eLife 2022）"@ja ; :url <https://elifesciences.org/articles/77007> ] ,
               [ dct:title "Long-term iPSC maintenance by automated culture system（Konagaya 2015）"@ja ; :url <https://www.ncbi.nlm.nih.gov/pmc/articles/PMC4647834/> ] .
:n_d4 a :Domain ;
    rdfs:label "プロセス制御・自律最適化"@ja ;
    :content "観察→判断→操作の閉ループと、プロトコル最適化（ベイズ最適化等）を担う制御知能の層。"@ja ;
    :inDomain :n_d4 ;
    :hasSource [ dct:title "Robotic search for optimal cell culture（Kanda et al., eLife 2022）"@ja ; :url <https://elifesciences.org/articles/77007> ] ,
               [ dct:title "ヒューマノイドロボットとAIによる自律細胞培養（理研 2020）"@ja ; :url <https://www.riken.jp/press/2020/20201204_1/index.html> ] .
:n_d5 a :Domain ;
    rdfs:label "ソフトウェア基盤・相互運用"@ja ;
    :content "デバイス統合標準・ワークフローオーケストレーション・データ基盤。異種機器を跨ぐ統合の土台。"@ja ;
    :inDomain :n_d5 ;
    :hasSource [ dct:title "SiLA 2 FAQ（HTTP/2 + Protocol Buffers, OPC-UA比較）"@ja ; :url <https://sila-standard.com/faq/> ] ,
               [ dct:title "The SiLA 2 Manager（device discovery / data integrity）"@ja ; :url <https://www.sciencedirect.com/science/article/pii/S2352711022000103> ] .
:n_d6 a :Domain ;
    rdfs:label "GMP・規制・データインテグリティ"@ja ;
    :content "製造ソフトが満たすべき規制・品質・電子記録の要件群。設計の制約条件を規定する。"@ja ;
    :inDomain :n_d6 ;
    :hasSource [ dct:title "GCTP適合性調査（PMDA）"@ja ; :url <https://www.pmda.go.jp/review-services/gmp-qms-gctp/gctp/0002.html> ] ,
               [ dct:title "Cell & Gene Therapy QC/QA（ALCOA, Part 11, CAPA）"@ja ; :url <https://www.cellandgene.com/topic/cell-gene-therapy-qa-qc> ] .
:n_d7 a :Domain ;
    rdfs:label "センサ・環境モニタリング"@ja ;
    :content "培養環境・無菌性の連続計測と、閉ループ制御への状態量供給。エッジ実装で分散計測。"@ja ;
    :inDomain :n_d7 ;
    :hasSource [ dct:title "Long-term iPSC maintenance by automated culture system（Konagaya 2015）"@ja ; :url <https://www.ncbi.nlm.nih.gov/pmc/articles/PMC4647834/> ] .
:n_d8 a :Domain ;
    rdfs:label "エコシステム・プレイヤー"@ja ;
    :content "財団・企業・装置など実在の担い手と製品。技術選定とパートナリングの地図。"@ja ;
    :inDomain :n_d8 ;
    :hasSource [ dct:title "iPS財団 My iPSプロジェクト（自家細胞を自動作製）"@ja ; :url <https://www.nikkan.co.jp/articles/view/00745986> ] ,
               [ dct:title "Terumo BCT × CiRA Foundation 自動化提携（Quantum Flex）"@ja ; :url <https://www.terumo.com/newsrelease/detail/20240319/6146> ] .
:n_maint a :Concept ;
    rdfs:label "iPSC維持培養"@ja ;
    :content "未分化状態を保つ日々の培地交換と環境維持。ヒトiPSは毎日の培地交換と約3日ごとの継代が必要で、熟練手技に依存する点が自動化の主対象。"@ja ;
    :inDomain :n_d1 ;
    :hasSource [ dct:title "CiRA ヒトiPS細胞 培養プロトコール集"@ja ; :url <https://www.cira.kyoto-u.ac.jp/j/research/protocol.html> ] ,
               [ dct:title "Long-term iPSC maintenance by automated culture system（Konagaya 2015）"@ja ; :url <https://www.ncbi.nlm.nih.gov/pmc/articles/PMC4647834/> ] .
:n_passage a :Concept ;
    rdfs:label "継代（剥離・分散）"@ja ;
    :content "コロニーを剥離し新プレートへ植え継ぐ工程。単一細胞分散かクランプ維持か、ROCK阻害剤(Y-27632)添加、シェアストレス管理が品質を左右する。"@ja ;
    :inDomain :n_d1 ;
    :hasSource [ dct:title "CiRA ヒトiPS細胞 培養プロトコール集"@ja ; :url <https://www.cira.kyoto-u.ac.jp/j/research/protocol.html> ] ,
               [ dct:title "Robotic search for optimal cell culture（Kanda et al., eLife 2022）"@ja ; :url <https://elifesciences.org/articles/77007> ] .
:n_feeder a :Concept ;
    rdfs:label "フィーダーフリー培養"@ja ;
    :content "フィーダー細胞を用いず基質コート上で培養する方式。臨床・自動化に適し、画像解析でも背景が単純化しやすい。"@ja ;
    :inDomain :n_d1 ;
    :hasSource [ dct:title "CiRA ヒトiPS細胞 培養プロトコール集"@ja ; :url <https://www.cira.kyoto-u.ac.jp/j/research/protocol.html> ] .
:n_diff a :Concept ;
    rdfs:label "分化誘導プロトコル"@ja ;
    :content "目的細胞へ誘導する多段階手順。iPSC→RPEは seeding / preconditioning / passage / induction / maintenance の5段階として定式化され、自動探索のテンプレになった。"@ja ;
    :inDomain :n_d1 ;
    :hasSource [ dct:title "Robotic search for optimal cell culture（Kanda et al., eLife 2022）"@ja ; :url <https://elifesciences.org/articles/77007> ] .
:n_signal a :Concept ;
    rdfs:label "シグナル制御（添加因子）"@ja ;
    :content "分化方向を決める阻害剤の濃度・タイミング。RPE誘導では FGFR阻害剤・SB431542(TGFβ)・CKI-7(Wnt)・Y-27632 等が制御変数。これらが最適化の探索空間になる。"@ja ;
    :inDomain :n_d1 ;
    :hasSource [ dct:title "Robotic search for optimal cell culture（Kanda et al., eLife 2022）"@ja ; :url <https://elifesciences.org/articles/77007> ] .
:n_suspension a :Concept ;
    rdfs:label "浮遊・懸濁培養（量産）"@ja ;
    :content "3次元浮遊撹拌で容積当たり密度を上げ量産する方式。突発的分化を化合物で抑制し、樹立→大量培養→直接凍結まで一貫化。自動化・スケールアップの基盤形態。"@ja ;
    :inDomain :n_d1 ;
    :hasSource [ dct:title "iPS細胞を浮遊培養で樹立・大量培養（理研, eLife）"@ja ; :url <https://www.riken.jp/press/2024/20241120_1/index.html> ] ,
               [ dct:title "iPS樹立から大量培養まで一貫（CiRA財団共著, eLife）"@ja ; :url <https://stemcells.or.jp/ips-9/> ] .
:n_reprog a :Concept ;
    rdfs:label "iPSC樹立（初期化）"@ja ;
    :content "体細胞をRNA等で初期化しコロニーを得る最難関工程。形態が動的で良質コロニー選抜が職人技。財団・パナソニックが2026年に樹立工程の自動化実証に着手。"@ja ;
    :inDomain :n_d1 ;
    :hasSource [ dct:title "パナソニックHD iPS樹立工程の自動化 実証実験（2026/4）"@ja ; :url <https://prtimes.jp/main/html/rd/p/000006702.000003442.html> ] ,
               [ dct:title "ML label-free iPSC colony formation detection（Sci Rep）"@ja ; :url <https://www.nature.com/articles/s41598-017-13680-x> ] .
:n_qccrit a :Concept ;
    rdfs:label "細胞品質基準"@ja ;
    :content "未分化マーカー発現・三胚葉分化能・核型など、製造物が満たすべき生物学的基準。自動判定の「正解ラベル」を定義し、画像代理指標と紐づける必要がある。【BO適性, 2026-06-15】per-run目的項=収量×生存率×多能性%陽性(フローサイト; OCT3/4・TRA-1-60・SSEA5が cross-lab 最ロバスト)。同一性(STR)・核型/CNV(KaryoStat 3-4日/G-band 7-10日, ~70%株がCNV保有→periodic監視)・残存未分化(上清miR-302b 0.001%非破壊)はoffline/periodic制約。ラベルフリー画像代理は未確立(要検証)。"@ja ;
    :inDomain :n_d1 ;
    :hasSource [ dct:title "Parametric analysis of hPSC colony morphology for QC（Sci Rep）"@ja ; :url <https://www.nature.com/articles/srep34009> ] ,
               [ dct:title "Long-term iPSC maintenance by automated culture system（Konagaya 2015）"@ja ; :url <https://www.ncbi.nlm.nih.gov/pmc/articles/PMC4647834/> ] ,
               [ dct:title "国際多施設 QAR: OCT3/4・TRA-1-60・SSEA5 が最ロバスト多能性マーカー (Stem Cell Reports 2026)"@ja ; :url <https://www.cell.com/stem-cell-reports/fulltext/S2213-6711(26)00068-8> ] ,
               [ dct:title "GMP hiPSC バッチリリース assay 検証 (Cytotherapy 2024)"@ja ; :url <https://www.sciencedirect.com/science/article/pii/S1465324924006108> ] ,
               [ dct:title "上清 miR-302b で残存未分化 0.001% 非破壊検出 (Sci Rep 2022)"@ja ; :url <https://www.nature.com/articles/s41598-022-14273-z> ] .
:n_bf a :Concept ;
    rdfs:label "明視野/位相差イメージング"@ja ;
    :content "低光毒性で非侵襲なラベルフリー観察。一方で低コントラスト・不均一背景・ハロー/エッジ効果があり、頑健なセグメンテーションが難所。"@ja ;
    :inDomain :n_d2 ;
    :hasSource [ dct:title "Deep learning for label-free monitoring of iPSC & organoids"@ja ; :url <https://www.moleculardevices.com/en/assets/app-note/dd/img/deep-learning-based-image-analysis-for-label-free-live-monitoring-of-ipsc-and-3d-organoid-cultures> ] .
:n_conf a :Concept ;
    rdfs:label "コンフルエンシー算出"@ja ;
    :content "セグメンテーションで占有面積/コロニー面積を定量。継代や次工程移行の判断指標（例: 70-80%）として閾値化される中核メトリクス。"@ja ;
    :inDomain :n_d2 ;
    :hasSource [ dct:title "Automation of iPSC culture/passaging with CellXpress.ai（Molecular Devices）"@ja ; :url <https://www.moleculardevices.com/en/assets/app-note/dd/3d-biology/automation-of-ipsc-culture-passaging-and-expansion-with-cellxpress-ai-automated-cell-culture-system> ] ,
               [ dct:title "Deep learning for label-free monitoring of iPSC & organoids"@ja ; :url <https://www.moleculardevices.com/en/assets/app-note/dd/img/deep-learning-based-image-analysis-for-label-free-live-monitoring-of-ipsc-and-3d-organoid-cultures> ] .
:n_morphcls a :Concept ;
    rdfs:label "コロニー形態分類"@ja ;
    :content "良/不良フェノタイプをCNN等で識別。形態パラメータが未分化性・クローン性維持能と相関し、選抜・除外の自動判断に使う。"@ja ;
    :inDomain :n_d2 ;
    :hasSource [ dct:title "QC of hPSC colonies by CNN image analysis"@ja ; :url <https://www.ncbi.nlm.nih.gov/pmc/articles/PMC9820636/> ] ,
               [ dct:title "Parametric analysis of hPSC colony morphology for QC（Sci Rep）"@ja ; :url <https://www.nature.com/articles/srep34009> ] .
:n_diffdet a :Concept ;
    rdfs:label "分化領域検出"@ja ;
    :content "未分化コロニー内の自発分化領域を検出・定量。分化率の閾値超過ウェルを除外したり、誘導の進行度評価に用いる専用DLモデル。"@ja ;
    :inDomain :n_d2 ;
    :hasSource [ dct:title "Automation of iPSC culture/passaging with CellXpress.ai（Molecular Devices）"@ja ; :url <https://www.moleculardevices.com/en/assets/app-note/dd/3d-biology/automation-of-ipsc-culture-passaging-and-expansion-with-cellxpress-ai-automated-cell-culture-system> ] ,
               [ dct:title "Deep learning for label-free monitoring of iPSC & organoids"@ja ; :url <https://www.moleculardevices.com/en/assets/app-note/dd/img/deep-learning-based-image-analysis-for-label-free-live-monitoring-of-ipsc-and-3d-organoid-cultures> ] .
:n_growth a :Concept ;
    rdfs:label "増殖曲線予測→継代トリガ"@ja ;
    :content "定期観察から面積値の増殖曲線を推定し、目標密度到達の至適時刻を予測。これがスケジューラと継代操作のトリガになる閉ループの起点。"@ja ;
    :inDomain :n_d2 ;
    :hasSource [ dct:title "ヒューマノイドロボットとAIによる自律細胞培養（理研 2020）"@ja ; :url <https://www.riken.jp/press/2020/20201204_1/index.html> ] ,
               [ dct:title "Automation of iPSC culture/passaging with CellXpress.ai（Molecular Devices）"@ja ; :url <https://www.moleculardevices.com/en/assets/app-note/dd/3d-biology/automation-of-ipsc-culture-passaging-and-expansion-with-cellxpress-ai-automated-cell-culture-system> ] .
:n_dlmodel a :Concept ;
    rdfs:label "DLモデル（分割/分類）"@ja ;
    :content "セグメンテーション(面積/コンフルエンシー)と分類(形態・分化)の学習モデル群。ラベルフリー前提・低コントラスト対応・施設間汎化が実装課題。"@ja ;
    :inDomain :n_d2 ;
    :hasSource [ dct:title "Deep learning for label-free monitoring of iPSC & organoids"@ja ; :url <https://www.moleculardevices.com/en/assets/app-note/dd/img/deep-learning-based-image-analysis-for-label-free-live-monitoring-of-ipsc-and-3d-organoid-cultures> ] ,
               [ dct:title "QC of hPSC colonies by CNN image analysis"@ja ; :url <https://www.ncbi.nlm.nih.gov/pmc/articles/PMC9820636/> ] .
:n_dualarm a :Concept ;
    rdfs:label "双腕ヒューマノイド"@ja ;
    :content "汎用器具をそのまま扱える人型双腕（例: LabDroid Maholo）。プロトコル変更に柔軟で、パラメータ探索や手作業の写像に向く。"@ja ;
    :inDomain :n_d3 ;
    :hasSource [ dct:title "Robotic search for optimal cell culture（Kanda et al., eLife 2022）"@ja ; :url <https://elifesciences.org/articles/77007> ] ,
               [ dct:title "ヒューマノイドロボットとAIによる自律細胞培養（理研 2020）"@ja ; :url <https://www.riken.jp/press/2020/20201204_1/index.html> ] .
:n_closeddev a :Concept ;
    rdfs:label "閉鎖型専用培養装置"@ja ;
    :content "装置内で取り出さず培養するクローズド機。無菌性・更衣簡略化・人為ミス低減に優れ、財団のmy iPS製造の中核アーキテクチャ。"@ja ;
    :inDomain :n_d3 ;
    :hasSource [ dct:title "iPS財団 My iPSプロジェクト（自家細胞を自動作製）"@ja ; :url <https://www.nikkan.co.jp/articles/view/00745986> ] ,
               [ dct:title "Long-term iPSC maintenance by automated culture system（Konagaya 2015）"@ja ; :url <https://www.ncbi.nlm.nih.gov/pmc/articles/PMC4647834/> ] .
:n_dispense a :Concept ;
    rdfs:label "自動分注・ピペッティング"@ja ;
    :content "培地・試薬の精密分注と吸引。液面追従・体積制御・無菌チップ運用が再現性を決める。リキッドハンドラ統合の基本ユニット。"@ja ;
    :inDomain :n_d3 ;
    :hasSource [ dct:title "Long-term iPSC maintenance by automated culture system（Konagaya 2015）"@ja ; :url <https://www.ncbi.nlm.nih.gov/pmc/articles/PMC4647834/> ] .
:n_transport a :Concept ;
    rdfs:label "プレート搬送・把持"@ja ;
    :content "インキュベータ⇄顕微鏡⇄作業台間のプレート/容器搬送とグリッパ制御。スケジュールに沿う物流が自律運転の連続性を支える。"@ja ;
    :inDomain :n_d3 ;
    :hasSource [ dct:title "ヒューマノイドロボットとAIによる自律細胞培養（理研 2020）"@ja ; :url <https://www.riken.jp/press/2020/20201204_1/index.html> ] ,
               [ dct:title "SiLA2: cell culture autopilot / vendor-agnostic"@ja ; :url <https://www.researchgate.net/publication/360985834_SiLA_2_The_Next_Generation_Lab_Automation_Standard> ] .
:n_motioncap a :Concept ;
    rdfs:label "熟練手技のモーション再現"@ja ;
    :content "熟練者の作業を動作解析し数値化してロボットで再現する思想。「誰でもできるよう数値化して自動化」が財団の自動化方針の核。"@ja ;
    :inDomain :n_d3 ;
    :hasSource [ dct:title "免疫拒絶のない「my iPS細胞」を全自動で作製へ（Science Portal）"@ja ; :url <https://scienceportal.jst.go.jp/newsflash/20250403_n01/> ] ,
               [ dct:title "がん治療に役立つ細胞の分化・培養を自動化（Panasonic）"@ja ; :url <https://news.panasonic.com/jp/stories/17100> ] .
:n_sched a :Concept ;
    rdfs:label "スケジューリング"@ja ;
    :content "12時間ごとの観察など定期タスクと、至適継代時刻のような条件起動タスクを編成。多細胞株・多バッチの並行運転を破綻なく回す制御層。"@ja ;
    :inDomain :n_d4 ;
    :hasSource [ dct:title "ヒューマノイドロボットとAIによる自律細胞培養（理研 2020）"@ja ; :url <https://www.riken.jp/press/2020/20201204_1/index.html> ] .
:n_loop a :Concept ;
    rdfs:label "クローズドループ判断"@ja ;
    :content "観察→判断→操作のサイクルを人手介入なしで回す。画像メトリクスを意思決定点に変換し、通知か次工程実行かを分岐する制御ロジック。"@ja ;
    :inDomain :n_d4 ;
    :hasSource [ dct:title "ヒューマノイドロボットとAIによる自律細胞培養（理研 2020）"@ja ; :url <https://www.riken.jp/press/2020/20201204_1/index.html> ] ,
               [ dct:title "Automation of iPSC culture/passaging with CellXpress.ai（Molecular Devices）"@ja ; :url <https://www.moleculardevices.com/en/assets/app-note/dd/3d-biology/automation-of-ipsc-culture-passaging-and-expansion-with-cellxpress-ai-automated-cell-culture-system> ] .
:n_bbo a :Concept ;
    rdfs:label "バッチベイズ最適化"@ja ;
    :content "数百万通りの培養条件を、ガウス過程＋バッチ取得関数で効率探索。RPE分化率を反復改善した自律実験の中核解法（GPyOptベース）。【検証2026-06-15】Kanda 2022は単一目的=画像由来の色素化スコア(day34 RPE面積比=分化誘導効率)、batch BO(GP+Expected Improvement+Batch Contextual Local Penalization, GPyOpt)、7パラメタ/143条件/111日で88%改善(0.91 vs 0.43)。単一目的 batch BO が iPSC で実証済(現代等価=Ax/BoTorch)。auto_cell 拡大BOの目的はqccrit由来=収量×生存率×多能性%陽性。"@ja ;
    :inDomain :n_d4 ;
    :hasSource [ dct:title "Robotic search for optimal cell culture（Kanda et al., eLife 2022）"@ja ; :url <https://elifesciences.org/articles/77007> ] ,
               [ dct:title "LabDroid_optimizer（GitHub / GPyOpt）"@ja ; :url <https://github.com/labauto/LabDroid_optimizer> ] .
:n_doe a :Concept ;
    rdfs:label "実験計画の定式化"@ja ;
    :content "プロトコルをパラメータ空間に写像し、最適化問題として定義する工程。各操作を変数化（濃度・日数・剥離強度等）し探索可能にする前処理。"@ja ;
    :inDomain :n_d4 ;
    :hasSource [ dct:title "Robotic search for optimal cell culture（Kanda et al., eLife 2022）"@ja ; :url <https://elifesciences.org/articles/77007> ] .
:n_sdl a :Concept ;
    rdfs:label "自律実験 / Self-driving Lab"@ja ;
    :content "ロボットが自ら結果を評価し次実験を計画する枠組み。再現性ある細胞製造に向け、探索空間の系統的・無バイアス探索を加速する。"@ja ;
    :inDomain :n_d4 ;
    :hasSource [ dct:title "Robotic search for optimal cell culture（Kanda et al., eLife 2022）"@ja ; :url <https://elifesciences.org/articles/77007> ] ,
               [ dct:title "Implementing robotics and AI（eLife digest）"@ja ; :url <https://elifesciences.org/articles/80609> ] .
:n_rl a :Concept ;
    rdfs:label "強化学習（発展領域）"@ja ;
    :content "方策学習による操作・条件最適化。製造GMP文脈では検証可能性が壁で、現状は画像判断・BOが主流、RLは研究段階。"@ja ;
    :inDomain :n_d4 ;
    :hasSource [ dct:title "Implementing robotics and AI（eLife digest）"@ja ; :url <https://elifesciences.org/articles/80609> ] .
:n_sila a :Concept ;
    rdfs:label "SiLA 2（デバイス標準）"@ja ;
    :content "HTTP/2＋Protocol BuffersとFeature Definition Languageで意味的に同一なデバイスIFを標準化。ベンダロックイン回避と統合工数削減の中核。"@ja ;
    :inDomain :n_d5 ;
    :hasSource [ dct:title "SiLA 2 FAQ（HTTP/2 + Protocol Buffers, OPC-UA比較）"@ja ; :url <https://sila-standard.com/faq/> ] ,
               [ dct:title "Tecan SiLA2 SDK（royalty-free, open-source）"@ja ; :url <https://slas-technology.org/article/S2472-6303(23)00044-4/fulltext> ] .
:n_opcua a :Concept ;
    rdfs:label "OPC-UA / LADS"@ja ;
    :content "産業で普及するM2M標準OPC-UAと、その研究室向けコンパニオン規格LADS。SiLA2と並ぶデバイス通信の選択肢で、製造ライン連携に強い。【P3】LADS v1.0.0(2024年1月, OPC Foundation+Spectaris+VDMA)はバイオリアクタを明示的にモデル化—Functional Unit×Function(analogセンサ/controller/program)構成で、auto_cellのchannel_config/tool_schemas/EBRに直接対応。Eppendorf DASware等プロセス制御機はOPC公開。A層バイオリアクタ制御のデバイスIF第一候補。"@ja ;
    :inDomain :n_d5 ;
    :hasSource [ dct:title "Tecan SiLA2 SDK（royalty-free, open-source）"@ja ; :url <https://slas-technology.org/article/S2472-6303(23)00044-4/fulltext> ] .
:n_mtp a :Concept ;
    rdfs:label "MTP（モジュール型パッケージ）"@ja ;
    :content "モジュール式・柔軟自動化を可能にする記述。SiLA2と組み合わせ、R&Dから製造へのスケールを支える構成管理の枠組み。"@ja ;
    :inDomain :n_d5 ;
    :hasSource [ dct:title "SiLA 2 FAQ（HTTP/2 + Protocol Buffers, OPC-UA比較）"@ja ; :url <https://sila-standard.com/faq/> ] .
:n_orch a :Concept ;
    rdfs:label "ワークフロー・オーケストレーション"@ja ;
    :content "タスクとデータと物理ハードを途切れなく統合する制御フレーム（AlabOS, Helao 等）。各機器をサービス化し横断ワークフローを管理。"@ja ;
    :inDomain :n_d5 ;
    :hasSource [ dct:title "SiLA2: cell culture autopilot / vendor-agnostic"@ja ; :url <https://www.researchgate.net/publication/360985834_SiLA_2_The_Next_Generation_Lab_Automation_Standard> ] .
:n_gateway a :Concept ;
    rdfs:label "レガシーデバイス・ゲートウェイ"@ja ;
    :content "独自IFしか持たない既存機器を標準IFへ橋渡しするゲートウェイ層。GPIO/USB/シリアル接続と遠隔監視で「スマート化」する。"@ja ;
    :inDomain :n_d5 ;
    :hasSource [ dct:title "The SiLA 2 Manager（device discovery / data integrity）"@ja ; :url <https://www.sciencedirect.com/science/article/pii/S2352711022000103> ] .
:n_lims a :Concept ;
    rdfs:label "LIMS / LES（情報・実行系）"@ja ;
    :content "検体・試薬・手順・結果を記録/指図する上位システム。デバイス層からのデータを集約し、バッチ記録・トレーサビリティに接続する。"@ja ;
    :inDomain :n_d5 ;
    :hasSource [ dct:title "The SiLA 2 Manager（device discovery / data integrity）"@ja ; :url <https://www.sciencedirect.com/science/article/pii/S2352711022000103> ] ,
               [ dct:title "Cell & Gene Therapy QC/QA（ALCOA, Part 11, CAPA）"@ja ; :url <https://www.cellandgene.com/topic/cell-gene-therapy-qa-qc> ] .
:n_datamodel a :Concept ;
    rdfs:label "データモデル / インジェスト"@ja ;
    :content "画像・センサ・操作ログの標準化された取り込み。新旧機器の異種IFを跨いだ「データ取り込みギャップ」の解消が自律運転の前提。"@ja ;
    :inDomain :n_d5 ;
    :hasSource [ dct:title "SiLA2: cell culture autopilot / vendor-agnostic"@ja ; :url <https://www.researchgate.net/publication/360985834_SiLA_2_The_Next_Generation_Lab_Automation_Standard> ] ,
               [ dct:title "The SiLA 2 Manager（device discovery / data integrity）"@ja ; :url <https://www.sciencedirect.com/science/article/pii/S2352711022000103> ] .
:n_gctp a :Concept ;
    rdfs:label "GCTP（再生医療等製品製造管理）"@ja ;
    :content "再生医療等製品の製造・品質管理基準。製造設備に加え管理手法の適合性をPMDAが調査。製造ソフトの設計境界を規定する。"@ja ;
    :inDomain :n_d6 ;
    :hasSource [ dct:title "GCTP適合性調査（PMDA）"@ja ; :url <https://www.pmda.go.jp/review-services/gmp-qms-gctp/gctp/0002.html> ] .
:n_ramlaw a :Concept ;
    rdfs:label "再生医療等安全性確保法 / 施設基準"@ja ;
    :content "細胞培養加工施設の構造設備基準と適合性調査の根拠法。my iPS製造施設はこの枠組みでPMDA適合性調査を受け稼働を目指す。"@ja ;
    :inDomain :n_d6 ;
    :hasSource [ dct:title "再生医療等安全性確保法 関連（Science Portal）"@ja ; :url <https://scienceportal.jst.go.jp/newsflash/20250403_n01/> ] ,
               [ dct:title "免疫拒絶のない「my iPS細胞」を全自動で作製へ（Science Portal）"@ja ; :url <https://scienceportal.jst.go.jp/newsflash/20250403_n01/> ] .
:n_alcoa a :Concept ;
    rdfs:label "ALCOA+ データインテグリティ"@ja ;
    :content "帰属性・判読性・同時性・原本性・正確性＋αを全ライフサイクルで満たす原則。製造/解析で生成する全データが従うべき設計要件。"@ja ;
    :inDomain :n_d6 ;
    :hasSource [ dct:title "Cell & Gene Therapy QC/QA（ALCOA, Part 11, CAPA）"@ja ; :url <https://www.cellandgene.com/topic/cell-gene-therapy-qa-qc> ] .
:n_csv a :Concept ;
    rdfs:label "CSV / CSA（システムバリデーション）"@ja ;
    :content "計算機システムが目的適合かつALCOA+準拠であることを文書化した証拠。技術的統制で担保するのは複雑で時間を要するが必須工程。"@ja ;
    :inDomain :n_d6 ;
    :hasSource [ dct:title "Cell & Gene Therapy QC/QA（ALCOA, Part 11, CAPA）"@ja ; :url <https://www.cellandgene.com/topic/cell-gene-therapy-qa-qc> ] .
:n_part11 a :Concept ;
    rdfs:label "21 CFR Part 11 / Annex 11"@ja ;
    :content "電子記録・電子署名の監査性と安全な取扱いを求めるFDA/EU規制。電子系の設計（権限・署名・改ざん防止）の直接要件。"@ja ;
    :inDomain :n_d6 ;
    :hasSource [ dct:title "Cell & Gene Therapy QC/QA（ALCOA, Part 11, CAPA）"@ja ; :url <https://www.cellandgene.com/topic/cell-gene-therapy-qa-qc> ] .
:n_ebr a :Concept ;
    rdfs:label "電子バッチ記録（EBR）"@ja ;
    :content "製造工程で生成される改ざん不能な電子記録。前工程データの検証で次工程の整合を担保し、逸脱時の是正を可能にする。"@ja ;
    :inDomain :n_d6 ;
    :hasSource [ dct:title "Cell & Gene Therapy QC/QA（ALCOA, Part 11, CAPA）"@ja ; :url <https://www.cellandgene.com/topic/cell-gene-therapy-qa-qc> ] .
:n_audit a :Concept ;
    rdfs:label "監査証跡（Audit Trail）"@ja ;
    :content "誰が・いつ・何を変更したかを追える記録。データインテグリティとPart11準拠の中核で、全操作のロギング設計が必要。"@ja ;
    :inDomain :n_d6 ;
    :hasSource [ dct:title "Cell & Gene Therapy QC/QA（ALCOA, Part 11, CAPA）"@ja ; :url <https://www.cellandgene.com/topic/cell-gene-therapy-qa-qc> ] .
:n_capa a :Concept ;
    rdfs:label "CAPA / リスク管理（FMEA）"@ja ;
    :content "逸脱・品質事象の根本原因分析と是正/予防措置。FMEA等のリスク評価が製品・工程設計の判断を導く。ソフトの逸脱検知設計に直結。"@ja ;
    :inDomain :n_d6 ;
    :hasSource [ dct:title "Cell & Gene Therapy QC/QA（ALCOA, Part 11, CAPA）"@ja ; :url <https://www.cellandgene.com/topic/cell-gene-therapy-qa-qc> ] .
:n_envmon a :Concept ;
    rdfs:label "環境モニタリング（DO/pH/CO₂/温度）"@ja ;
    :content "培養環境の連続計測。維持培養や量産の安定性を支え、閉ループ制御の状態量を供給する。エッジ実装（ESP32等）で分散計測が可能。"@ja ;
    :inDomain :n_d7 ;
    :hasSource [ dct:title "Long-term iPSC maintenance by automated culture system（Konagaya 2015）"@ja ; :url <https://www.ncbi.nlm.nih.gov/pmc/articles/PMC4647834/> ] .
:n_sterility a :Concept ;
    rdfs:label "無菌性・コンタミ監視"@ja ;
    :content "菌混入や逸脱の検知。閉鎖系では更衣簡略化と引換えに監視設計が重要で、9日連続運転でも重大エラー/汚染ゼロが品質目標水準。"@ja ;
    :inDomain :n_d7 ;
    :hasSource [ dct:title "ヒューマノイドロボットとAIによる自律細胞培養（理研 2020）"@ja ; :url <https://www.riken.jp/press/2020/20201204_1/index.html> ] ,
               [ dct:title "免疫拒絶のない「my iPS細胞」を全自動で作製へ（Science Portal）"@ja ; :url <https://scienceportal.jst.go.jp/newsflash/20250403_n01/> ] .
:n_cpv a :Concept ;
    rdfs:label "インライン/アットライン分析（CPV）"@ja ;
    :content "工程内・近接でのリアルタイム計測で工程性能を継続検証(CPV)。AI/自動化が高スループットQCと工程安定性監視を可能にする。【P5】具体スタック(2026-06-15調査): VCD=in-line capacitance(Aber FUTURA/Hamilton Incyte, Manstein iPSCで定性検証), 代謝物=in-line Raman(CHOで閉ループglucose制御実証)＋at-line Nova BioProfile FLEX2(16項＋osmolality/viability), 凝集体径=in-line DHM(Ovizio)/FBRM(CLD≠径) or at-line画像(Kropp2019/FlowCam, 日次)。品質(未分化/同一性)・無菌はoffline=BO目的関数専用。"@ja ;
    :inDomain :n_d7 ;
    :hasSource [ dct:title "Cell & Gene Therapy QC/QA（ALCOA, Part 11, CAPA）"@ja ; :url <https://www.cellandgene.com/topic/cell-gene-therapy-qa-qc> ] ,
               [ dct:title "Krause et al. 2023, Curr Opin Biotechnol — biocapacitance online biomass"@ja ; :url <https://www.sciencedirect.com/science/article/pii/S0958166923000897> ] ,
               [ dct:title "Graf/Wei et al. 2022, Front Bioeng — in-line Raman closed-loop glucose (PID)"@ja ; :url <https://www.frontiersin.org/journals/bioengineering-and-biotechnology/articles/10.3389/fbioe.2022.719614/full> ] ,
               [ dct:title "Nova Biomedical BioProfile FLEX2 (16-parameter at-line analyzer)"@ja ; :url <https://www.novabiomedical.com/cell-culture-analyzers/bioprofile-flex2-basic/> ] ,
               [ dct:title "Kropp et al. 2019, Sci Rep — at-line bypass imaging of hiPSC aggregates"@ja ; :url <https://www.nature.com/articles/s41598-019-48814-w> ] .
:n_edge a :Concept ;
    rdfs:label "エッジセンサ統合"@ja ;
    :content "マイコン/IoTによる多点センサ取得とデバイス層への配信。標準IF（SiLA2/OPC-UA）やゲートウェイ経由で上位へ集約する接点。"@ja ;
    :inDomain :n_d7 ;
    :hasSource [ dct:title "The SiLA 2 Manager（device discovery / data integrity）"@ja ; :url <https://www.sciencedirect.com/science/article/pii/S2352711022000103> ] .
:n_cira a :Player ;
    rdfs:label "CiRA財団 / my iPS"@ja ;
    :content "自家iPSの閉鎖系フル自動製造を推進。約3週間・原材料費約100万円/人を掲げ、PMDA適合性調査・非臨床を経て2028年度の治験開始を目標。"@ja ;
    :inDomain :n_d8 ;
    :hasSource [ dct:title "iPS財団 My iPSプロジェクト（自家細胞を自動作製）"@ja ; :url <https://www.nikkan.co.jp/articles/view/00745986> ] ,
               [ dct:title "免疫拒絶のない「my iPS細胞」を全自動で作製へ（Science Portal）"@ja ; :url <https://scienceportal.jst.go.jp/newsflash/20250403_n01/> ] ,
               [ dct:title "my iPSプロジェクト（iPS財団 公式）"@ja ; :url <https://www.cira-foundation.or.jp/j/about/project/myips/> ] .
:n_terumo a :System ;
    rdfs:label "Terumo BCT / Quantum Flex"@ja ;
    :content "2024年に財団と提携。Quantum Flex Cell Expansion System上で閉鎖・自動・統合プロセスを構築し、デジタル技術で効率と制御を高める。【P3】Quantum FlexはCPAソフト(プロトコルビルダ/最大100台フリート/cGMP)の閉鎖ターンキーで、公開デバイスAPIは確認できず＝自前ブレインの閉ループ制御対象ではなく商用/臨床エンドポイント(連携するなら監視のみ)。"@ja ;
    :inDomain :n_d8 ;
    :hasSource [ dct:title "Terumo BCT × CiRA Foundation 自動化提携（Quantum Flex）"@ja ; :url <https://www.terumo.com/newsrelease/detail/20240319/6146> ] .
:n_pana a :Player ;
    rdfs:label "パナソニックHD"@ja ;
    :content "岩田研由来の閉鎖型自動培養の系譜。2026年4月、中之島クロスでiPS樹立工程の自動化実証を開始し、最難関の樹立に踏み込む。"@ja ;
    :inDomain :n_d8 ;
    :hasSource [ dct:title "パナソニックHD iPS樹立工程の自動化 実証実験（2026/4）"@ja ; :url <https://prtimes.jp/main/html/rd/p/000006702.000003442.html> ] ,
               [ dct:title "がん治療に役立つ細胞の分化・培養を自動化（Panasonic）"@ja ; :url <https://news.panasonic.com/jp/stories/17100> ] .
:n_kaneka a :Player ;
    rdfs:label "カネカ × 理研（林洋平ら）"@ja ;
    :content "財団研究開発センターと共同で、樹立から大量培養までを一貫させた浮遊培養をeLifeに報告。量産・自動化の基盤形態を提供。"@ja ;
    :inDomain :n_d8 ;
    :hasSource [ dct:title "iPS細胞を浮遊培養で樹立・大量培養（理研, eLife）"@ja ; :url <https://www.riken.jp/press/2024/20241120_1/index.html> ] ,
               [ dct:title "iPS樹立から大量培養まで一貫（CiRA財団共著, eLife）"@ja ; :url <https://stemcells.or.jp/ips-9/> ] .
:n_rbi a :System ;
    rdfs:label "Robotic Biology Institute / Maholo"@ja ;
    :content "双腕ヒューマノイドLabDroid Maholoの提供元。汎用器具操作と高再現性で、自律探索プラットフォームの物理基盤を担う。"@ja ;
    :inDomain :n_d8 ;
    :hasSource [ dct:title "Robotic search for optimal cell culture（Kanda et al., eLife 2022）"@ja ; :url <https://elifesciences.org/articles/77007> ] .
:n_epistra a :Player ;
    rdfs:label "Epistra（自律最適化）"@ja ;
    :content "Maholo×AIの自律実験を支えた企業の一つ。実験計画・ベイズ最適化など最適化エンジン側で関与。"@ja ;
    :inDomain :n_d8 ;
    :hasSource [ dct:title "Robotic search for optimal cell culture（Kanda et al., eLife 2022）"@ja ; :url <https://elifesciences.org/articles/77007> ] .
:n_moldev a :System ;
    rdfs:label "Molecular Devices / CellXpress.ai"@ja ;
    :content "イメージングベースのAI判断で給餌・継代を自動化する商用システム。DLで形態/分化を識別し、24/365運転で複数株を拡大。"@ja ;
    :inDomain :n_d8 ;
    :hasSource [ dct:title "Automation of iPSC culture/passaging with CellXpress.ai（Molecular Devices）"@ja ; :url <https://www.moleculardevices.com/en/assets/app-note/dd/3d-biology/automation-of-ipsc-culture-passaging-and-expansion-with-cellxpress-ai-automated-cell-culture-system> ] ,
               [ dct:title "Deep learning for label-free monitoring of iPSC & organoids"@ja ; :url <https://www.moleculardevices.com/en/assets/app-note/dd/img/deep-learning-based-image-analysis-for-label-free-live-monitoring-of-ipsc-and-3d-organoid-cultures> ] .
:n_astellas a :Player ;
    rdfs:label "アステラス製薬（双腕ロボ）"@ja ;
    :content "双腕ロボットでiPS培養を自動化し、治験用供給を企図。製薬側からの製造自動化プレイヤー。"@ja ;
    :inDomain :n_d8 ;
    :hasSource [ dct:title "iPS細胞をロボが培養（アステラス, 日経）"@ja ; :url <https://www.nikkei.com/article/DGKKZO75692350Z21C23A0TB0000/> ] .
:n_src_kanda a :Source ;
    rdfs:label "Kanda et al. 2022 (eLife)"@ja ;
    :content "自律ロボット×バッチベイズ最適化でiPSC-RPE分化を最適化した記念碑的論文。プロトコルの5段階定式化とパラメータ探索、コード公開を含む。"@ja ;
    :inDomain :n_d4 ;
    :hasSource [ dct:title "Robotic search for optimal cell culture（Kanda et al., eLife 2022）"@ja ; :url <https://elifesciences.org/articles/77007> ] ,
               [ dct:title "LabDroid_optimizer（GitHub / GPyOpt）"@ja ; :url <https://github.com/labauto/LabDroid_optimizer> ] .
:n_src_riken2020 a :Source ;
    rdfs:label "理研 自律培養 2020"@ja ;
    :content "人型ロボット×AIで12h観察→増殖予測→至適継代を9日間自律実行。閉ループ自律培養の国内先行実証。"@ja ;
    :inDomain :n_d2 ;
    :hasSource [ dct:title "ヒューマノイドロボットとAIによる自律細胞培養（理研 2020）"@ja ; :url <https://www.riken.jp/press/2020/20201204_1/index.html> ] .
:n_src_sila a :Source ;
    rdfs:label "SiLA 2 標準群"@ja ;
    :content "デバイス相互運用の標準。Tecan SDK・SiLA2 Manager・cell culture autopilot事例まで、実装に直接使える資源群。"@ja ;
    :inDomain :n_d5 ;
    :hasSource [ dct:title "Tecan SiLA2 SDK（royalty-free, open-source）"@ja ; :url <https://slas-technology.org/article/S2472-6303(23)00044-4/fulltext> ] ,
               [ dct:title "The SiLA 2 Manager（device discovery / data integrity）"@ja ; :url <https://www.sciencedirect.com/science/article/pii/S2352711022000103> ] ,
               [ dct:title "SiLA2: cell culture autopilot / vendor-agnostic"@ja ; :url <https://www.researchgate.net/publication/360985834_SiLA_2_The_Next_Generation_Lab_Automation_Standard> ] .
:n_src_gctp a :Source ;
    rdfs:label "PMDA GCTP / 適合性調査"@ja ;
    :content "再生医療等製品の製造・品質管理の適合性を定める一次情報。製造ソフトの規制要件の出発点。"@ja ;
    :inDomain :n_d6 ;
    :hasSource [ dct:title "GCTP適合性調査（PMDA）"@ja ; :url <https://www.pmda.go.jp/review-services/gmp-qms-gctp/gctp/0002.html> ] .
:n_src_cgt a :Source ;
    rdfs:label "CGT QC/QA（ALCOA・Part11）"@ja ;
    :content "データインテグリティ・CSV・CAPA・CPVを横断する実務解説。電子系設計の要件マップとして有用。"@ja ;
    :inDomain :n_d6 ;
    :hasSource [ dct:title "Cell & Gene Therapy QC/QA（ALCOA, Part 11, CAPA）"@ja ; :url <https://www.cellandgene.com/topic/cell-gene-therapy-qa-qc> ] .
:n_src_cxa a :Source ;
    rdfs:label "CellXpress.ai 適用ノート"@ja ;
    :content "コンフルエンシー/分化のDL2モデルと閾値起動の自動継代を具体記述。画像→意思決定の設計参照。"@ja ;
    :inDomain :n_d2 ;
    :hasSource [ dct:title "Automation of iPSC culture/passaging with CellXpress.ai（Molecular Devices）"@ja ; :url <https://www.moleculardevices.com/en/assets/app-note/dd/3d-biology/automation-of-ipsc-culture-passaging-and-expansion-with-cellxpress-ai-automated-cell-culture-system> ] ,
               [ dct:title "Deep learning for label-free monitoring of iPSC & organoids"@ja ; :url <https://www.moleculardevices.com/en/assets/app-note/dd/img/deep-learning-based-image-analysis-for-label-free-live-monitoring-of-ipsc-and-3d-organoid-cultures> ] .
:n_src_susp a :Source ;
    rdfs:label "浮遊培養 一貫化（eLife）"@ja ;
    :content "樹立→大量培養→直接凍結まで浮遊系で一貫。量産・自動化の生物学的基盤。財団・理研・カネカ共同。"@ja ;
    :inDomain :n_d1 ;
    :hasSource [ dct:title "iPS細胞を浮遊培養で樹立・大量培養（理研, eLife）"@ja ; :url <https://www.riken.jp/press/2024/20241120_1/index.html> ] ,
               [ dct:title "iPS樹立から大量培養まで一貫（CiRA財団共著, eLife）"@ja ; :url <https://stemcells.or.jp/ips-9/> ] .
:n_kinetics a :Concept ;
    rdfs:label "浮遊培養速度論モデル（Tier2 plant 原典）"@ja ;
    :content "iPSC浮遊培養の比増殖速度をMonod型で表すin silicoモデル。auto_cell Tier2 plant_modelの原典はManstein & Zweigerdt 2021（SCTM/STAR Protocols, src_manstein）で、グルコース・乳酸・グルタミン・浸透圧・凝集体径の阻害項を持ち、灌流で7日35×10⁶ cells/mLを達成した過程制御モデル。Table1定数(µ=1.35/d, KGlc=1.5mM, KLac=50mM, KGln=0.01mM, KOsm=500mOsm/kg, KAgg=350/2=175µm径)はplant_modelと完全一致。Galvanauskas 2019(src_galv)は3項のみの近縁別モデル。"@ja ;
    :inDomain :n_d1 ;
    :hasSource [ dct:title "Kinetic modeling of hiPSC expansion in suspension culture（Galvanauskas et al., Regen Therapy 2019;12:88-93）"@ja ; :url <https://pmc.ncbi.nlm.nih.gov/articles/PMC6933447/> ] .
:n_src_galv a :Source ;
    rdfs:label "Galvanauskas et al. 2019 (近縁の3項モデル)"@ja ;
    :content "iPSC浮遊培養速度論の近縁モデル(Galvanauskas/Kino-Oka 2019, Regen Therapy 12:88-93)。グルコースMonod＋乳酸阻害＋凝集体体積阻害の3項のみで、グルタミン制限/浸透圧項は持たない(明示的に省略)。定数もplant_modelと異なる(µmax≈2.35/d, KG≈7mM, KAgg=5.6e6µm³体積)。deep-researchが一旦原典と誤推定したが、真の原典はManstein 2021(src_manstein)。"@ja ;
    :inDomain :n_d1 ;
    :hasSource [ dct:title "Kinetic modeling of hiPSC expansion in suspension culture（PMC6933447）"@ja ; :url <https://pmc.ncbi.nlm.nih.gov/articles/PMC6933447/> ] ,
               [ dct:title "PubMed 31890771"@ja ; :url <https://pubmed.ncbi.nlm.nih.gov/31890771/> ] .
:n_src_borys a :Source ;
    rdfs:label "Borys et al. 2021 (Stem Cell Res Ther)"@ja ;
    :content "iPSC Vertical-Wheel(PBS Biotech)撹拌最適化。40rpmが最大増殖(day6で32.3±3.2倍)、day5凝集体径169-275µm、>400µmで壊死予想。撹拌CPPの文献アンカー(最適40-60rpm、auto_cellの50-120rpm上限は高め)。"@ja ;
    :inDomain :n_d4 ;
    :hasSource [ dct:title "Borys et al. 2021, Stem Cell Res Ther 12:55（PMC7805206）"@ja ; :url <https://pmc.ncbi.nlm.nih.gov/articles/PMC7805206/> ] .
:n_src_kropp a :Source ;
    rdfs:label "Kropp/Lipsitz et al. 2015 (BMC Proceedings)"@ja ;
    :content "hPSC撹拌懸濁のBox-Behnken DoE。pH7.3/37℃、毎日給餌で高密度、播種2×10⁵が最適、DOは本研究で非有意。注: HES2(ESC)・Micro-24振盪式(400rpm=振盪周波数)でiPSC/インペラ槽への転用に注意。"@ja ;
    :inDomain :n_d4 ;
    :hasSource [ dct:title "Kropp et al. 2015, BMC Proceedings（PMC4685349）"@ja ; :url <https://pmc.ncbi.nlm.nih.gov/articles/PMC4685349/> ] .
:n_src_traj a :Source ;
    rdfs:label "Nogueira 2019 / Olmer 2012（到達密度 実測）"@ja ;
    :content "バッチ vs 灌流の到達密度差。標準バッチはNogueira(Vertical-Wheel)=peak 2.3×10⁶、Olmer(撹拌槽)=2.4×10⁶ cells/mL止まり。plant_modelの検証目標35×10⁶はManstein 2021の灌流プロセス(src_manstein)で達成される値で、バッチでは到達しない。"@ja ;
    :inDomain :n_d1 ;
    :hasSource [ dct:title "Nogueira et al. 2019, J Biol Eng（PMC6744632）"@ja ; :url <https://pmc.ncbi.nlm.nih.gov/articles/PMC6744632/> ] ,
               [ dct:title "Olmer et al. 2012, Tissue Eng Part C（PMC3460618）"@ja ; :url <https://pmc.ncbi.nlm.nih.gov/articles/PMC3460618/> ] .
:n_src_manstein a :Source ;
    rdfs:label "Manstein & Zweigerdt 2021（plant_model 原典）"@ja ;
    :content "auto_cell Tier2 plant_modelの真の原典。hPSC灌流撹拌槽培養をpH7.1/DO40%/浸透圧ピーク抑制/灌流で制御し、7日で70倍・35×10⁶ cells/mL(150mLで52.5億細胞)を達成。Monod型in silicoモデル(Table1: µ=1.35/d, KGlc=1.5mM, KLac=50mM, KGln=0.01mM, KOsm=500mOsm/kg, KAgg=350/2=175µm)はplant_modelの6定数と完全一致。撹拌80rpm(150mLスケール)。"@ja ;
    :inDomain :n_d4 ;
    :hasSource [ dct:title "Manstein et al. 2021, Stem Cells Transl Med 10(7):1063-1080（DOI 10.1002/sctm.20-0453, PMID 33660952）"@ja ; :url <https://pubmed.ncbi.nlm.nih.gov/33660952/> ] ,
               [ dct:title "Manstein et al. 2021, STAR Protocols 2(4):100988 — in silico model Table 1（PMC8666714）"@ja ; :url <https://pmc.ncbi.nlm.nih.gov/articles/PMC8666714/> ] .
:n_src_lads a :Source ;
    rdfs:label "OPC UA LADS v1.0.0 (OPC Foundation)"@ja ;
    :content "Laboratory and Analytical Device Standard。OPC-UAコンパニオン規格(2024-01, OPC Foundation+Spectaris+VDMA, OPC 30500-1)。Functional Unit/Function(sensor analog/discrete/multi-state, controller, actuator)＋Program/Result管理＋Asset/保守。バイオリアクタを明示例として槽=Functional Unit(温度センサ+モータ+program)でモデル化。auto_cellのDomainVertical面に直対応。"@ja ;
    :inDomain :n_d5 ;
    :hasSource [ dct:title "OPC UA for LADS Part 1 Basics (OPC 30500-1) — reference.opcfoundation.org"@ja ; :url <https://reference.opcfoundation.org/LADS/v100/docs/> ] ,
               [ dct:title "OPC UA LADS (SLAS standards)"@ja ; :url <https://www.slas.org/resources/standards/opc-ua-lads/> ] .
:n_ctrl_split a :Concept ;
    rdfs:label "制御権限の二層分界"@ja ;
    :content "協業前提でデバイスを設計指定するとき、安全クリティカルな高速ループはデバイス局所コントローラ(検証済PID: 温度37℃/pH7.1/DO40%/撹拌rpm, 秒オーダ・決定的)に置き、ReActブレインは監督制御(設定点変更・灌流/給餌率・サンプリング/継代トリガ・アラーム応答, 30秒+オーダ)に限定する。LLMは高速ループを閉じない(安全/CSV)。緊急停止・無菌バリア・ハード保安連動は安全系のみが強制し、ブレインは読み取りのみ。"@ja ;
    :inDomain :n_d4 ;
    :hasSource [ dct:title "Cell & Gene Therapy QC/QA（ALCOA, Part 11, CAPA）"@ja ; :url <https://www.cellandgene.com/topic/cell-gene-therapy-qa-qc> ] .
:n_devprofile a :Concept ;
    rdfs:label "デバイスプロファイル / ICD（協業の成果物）"@ja ;
    :content "協業でデバイス側に実装を指定する単一の情報モデル(Interface Control Document)。LADS/OPC-UAのFunctional Unit/Function/Programで表現し、これがdevice実装とauto_cellのDomainVertical(channel↔sensor Function, tool↔controller Function/method, EBR↔Program/Result, event↔alarm)を束ねる。setpoint範囲・単位・検証済包絡線を含み、second-source(別ベンダ実装)を可能にする。bespoke REST/gRPCを一次契約にしない。"@ja ;
    :inDomain :n_d5 ;
    :hasSource [ dct:title "OPC UA for LADS Part 1 Basics (OPC 30500-1) — reference.opcfoundation.org"@ja ; :url <https://reference.opcfoundation.org/LADS/v100/docs/> ] .

