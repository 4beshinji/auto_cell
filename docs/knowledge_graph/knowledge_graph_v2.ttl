    .

:n_measurement_aggregate_imaging a :Concept ;
    rdfs:label "at-line 凝集体画像計測"@ja ;
    :inDomain :n_d7 ;
    :content "FlowCam または Kropp 型バイパス顕微鏡による凝集体径・形態の画像解析。v1 では離散/日次運用が現実的。"@ja ;
    .

:n_measurement_fbrm_cld a :Concept ;
    rdfs:label "FBRM 弦長分布計測"@ja ;
    :inDomain :n_d7 ;
    :content "Mettler Toledo ParticleTrack による Focused Beam Reflectance Measurement。連続計測可能だが、CLD は真の粒径分布ではなく凝集体形状に依存。"@ja ;
    .

:n_measurement_ovizio_dhm a :Concept ;
    rdfs:label "Ovizio D3HM ホログラフィ計測"@ja ;
    :inDomain :n_d7 ;
    :content "Ovizio iLINE-F PRO の Double Differential Digital Holographic Microscopy。ラベルフリー連続細胞/凝集体モニタリング。iPSC 実証は限定的。"@ja ;
    .

:n_monitoring_ammonia_atline a :Concept ;
