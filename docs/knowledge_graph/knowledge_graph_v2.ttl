    .

:n_lads_functional_unit a :Concept ;
    rdfs:label "LADS Functional Unit"@ja ;
    :inDomain :n_d5 ;
    :content "LADS v1.0.0 で定義される機能単位。バイオリアクタ槽を 1 つの仮想デバイスとして集約し、内部に Sensor/Controller/Actuator Function と ProgramManager を持つ。"@ja ;
    .

:n_lads_sensor_function a :Concept ;
    rdfs:label "LADS Sensor Function"@ja ;
    :inDomain :n_d5 ;
    :content "LADS Functional Unit に属するセンサ機能（analog/discrete/multi-state）。pH/DO/Temp/Agitation/Capacitance/Raman/Pressure/Level/Foam 等が該当。"@ja ;
    .

:n_lads_controller_function a :Concept ;
    rdfs:label "LADS Controller Function"@ja ;
    :inDomain :n_d5 ;
    :content "LADS Functional Unit に属する制御機能。局所 PID（pH/DO/Temp/Agitation）の制御ロジックを内包し、ブレインからの検証済設定点を受け取る。"@ja ;
    .

:n_lads_actuator_function a :Concept ;
    rdfs:label "LADS Actuator Function"@ja ;
    :inDomain :n_d5 ;
    :content "LADS Functional Unit に属する駆動機能。灌流ポンプ、給餌ポンプ、培地交換弁、サンプリング弁等の離散/連続駆動素子を表す。"@ja ;
    .

:n_lads_program_result a :Concept ;
    rdfs:label "LADS Program/Result"@ja ;
    :inDomain :n_d5 ;
    :content "LADS ProgramManager が管理するプログラム（seed/passage/perfusion_ramp/clean）とその実行結果。EBR 導出の原材料となる。"@ja ;
    .

:n_sila_feature a :Concept ;
    rdfs:label "SiLA2 Feature"@ja ;
    :inDomain :n_d5 ;
    :content "SiLA2 Feature Definition Language（FDL）で定義される機能単位。サンプリングロボ、分注、at-line 分析器等のコマンド/property を記述。"@ja ;
    .

:n_mqtt_topic_contract a :Concept ;
    rdfs:label "MQTT topic contract"@ja ;
    :inDomain :n_d5 ;
    :content "auto_cell brain と device_gateway 間の MQTT topic 命名規則。cell/{culture_unit_id}/{direction}/{category}/{device_id}/{function_id} の形式。"@ja ;
    .

:n_gateway_cmd_ack a :Concept ;
    rdfs:label "Gateway command/ack correlation"@ja ;
    :inDomain :n_d5 ;
    :content "MQTT 5.0 Response Topic + Correlation Data を使った非同期 request-response。冪等キーと Message Expiry Interval による重複/stale コマンド防止。"@ja ;
    .

:n_icd_setpoint_envelope a :Concept ;
    rdfs:label "ICD setpoint envelope"@ja ;
    :inDomain :n_d4 ;
