    .

:n_peripheral_sampler a :System ;
    rdfs:label "SiLA2 サンプリングロボ"@ja ;
    :inDomain :n_d8 ;
    :content "SiLA2 で統合される at-line サンプリングロボ。take_sample コマンドを提供。"@ja ;
    .

:n_peripheral_dispenser a :System ;
    rdfs:label "SiLA2 自動分注器"@ja ;
    :inDomain :n_d8 ;
