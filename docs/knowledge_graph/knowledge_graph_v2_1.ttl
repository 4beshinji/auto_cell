n_approval_workflow a :Concept ;
    rdfs:label "Human-on-the-loop 承認ワークフロー"@ja ;
    :inDomain :n_d4 ;
    :content "requested → pending → approved/rejected/timeout → executed/cancelled の状態遷移。タイムアウト時は安全側に倒す。  [merged from multiple agents] L1/L2/L3 が自律実行しようとする包絡線外・重大アクションに対し、研究者の明示承認を得てから実行する状態遷移機構。requested → approved/rejected/pending_timeout → executed/cancelled。承認結果は監査証跡に不変ログ化される。"@ja ;
    :hasSource [ dct:title "auto_cell A 層要求仕様（Human-on-the-loop）"@ja ; :url <docs/design/requirements.md> ] ,
               [ dct:title "NIST AI Risk Management Framework（human-in-the-loop 概念）"@ja ; :url <https://www.nist.gov/itl/ai-risk-management-framework> ] ;
